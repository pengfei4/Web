<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="中秋诗词深度赏析——作者生平、逐行解析、情感主题、历史文化背景">
<title>诗词深度赏析 — <%= config.site_title %></title>
