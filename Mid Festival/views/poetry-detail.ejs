<link href="/css/animations.css" rel="stylesheet">
<style>
/* ============================================================
   诗词详情页 — 深度赏析
   ============================================================ */
.poetry-hero {
  position: relative;
  height: 38vh;
  min-height: 280px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(10,14,39,0.3) 0%, rgba(10,14,39,0.6) 50%, var(--deep-blue) 100%);
}
.poetry-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 30%, rgba(245,210,122,0.1) 0%, transparent 55%),
              radial-gradient(ellipse at 30% 60%, rgba(232,115,74,0.06) 0%, transparent 40%);
  pointer-events: none;
}
.poetry-hero .hero-content { text-align: center; position: relative; z-index: 2; animation: fadeInUp 0.8s ease; }
.poetry-hero h1 {
  font-family: var(--font-title); font-size: 2.8rem; color: var(--moon-gold);
  letter-spacing: 6px; margin-bottom: 8px; text-shadow: 0 0 40px rgba(245,210,122,0.3);
}
.poetry-hero .hero-desc { font-family: var(--font-poetry); font-size: 1.15rem; color: var(--text-secondary); letter-spacing: 3px; }

/* ---- 子导航 ---- */
.poetry-subnav {
  position: sticky; top: 70px; z-index: 998;
  background: rgba(10,14,39,0.92); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border-subtle); overflow-x: auto;
  scrollbar-width: none;
}
.poetry-subnav::-webkit-scrollbar { display: none; }
.poetry-subnav-inner {
  display: flex; gap: 0; max-width: 1300px; margin: 0 auto; padding: 0 10px;
  justify-content: center;
}
.poetry-subnav a {
  flex-shrink: 0; padding: 13px 14px; color: var(--text-secondary);
  font-family: var(--font-title); font-size: 0.82rem; letter-spacing: 1.5px;
  border-bottom: 2px solid transparent; transition: all 0.3s ease; text-decoration: none; white-space: nowrap;
}
.poetry-subnav a:hover, .poetry-subnav a.active { color: var(--moon-gold); border-bottom-color: var(--moon-gold); }

/* ---- 内容区 ---- */
.poetry-content { max-width: 1000px; margin: 0 auto; padding: 50px 20px 80px; }

/* ---- 诗歌详情节 ---- */
.poem-detail-section { padding: 60px 0; border-bottom: 1px solid var(--border-subtle); }
.poem-detail-section:last-child { border-bottom: none; }

/* 诗歌标题头 */
.poem-header {
  text-align: center; margin-bottom: 40px; padding: 35px;
  background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 16px;
}
.poem-header .ph-title {
  font-family: var(--font-title); font-size: 2.2rem; color: var(--moon-gold);
  letter-spacing: 5px; margin-bottom: 8px;
}
.poem-header .ph-author {
  font-family: var(--font-poetry); font-size: 1.1rem; color: var(--text-secondary); letter-spacing: 2px;
}
.poem-header .ph-dynasty {
  display: inline-block; margin-top: 10px; padding: 3px 14px;
  border: 1px solid rgba(201,169,110,0.3); border-radius: 12px;
  font-size: 0.78rem; color: var(--text-muted); letter-spacing: 2px;
}

/* 完整诗歌展示 */
.poem-full-display {
  background: linear-gradient(135deg, rgba(20,24,54,0.8), rgba(26,31,74,0.7));
  border: 1px solid var(--border-subtle); border-radius: 14px;
  padding: 40px; text-align: center; margin-bottom: 30px;
}
.poem-full-display .pfd-lines {
  font-family: var(--font-poetry); font-size: 1.15rem; color: var(--text-primary);
  line-height: 2.6; letter-spacing: 2px;
}

/* 内容卡片网格 */
.detail-card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 20px; }
.detail-card {
  background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 12px;
  padding: 28px; transition: all 0.35s ease;
}
.detail-card:hover { border-color: var(--border-glow); box-shadow: 0 4px 20px rgba(245,210,122,0.08); }
.detail-card.full-width { grid-column: span 2; }
.detail-card .dc-label {
  display: flex; align-items: center; gap: 10px; margin-bottom: 16px; padding-bottom: 14px;
  border-bottom: 1px solid rgba(201,169,110,0.15);
}
.dc-label .dc-icon { font-size: 1.6rem; }
.dc-label .dc-title { font-family: var(--font-title); font-size: 1.15rem; color: var(--moon-gold); letter-spacing: 2px; }
.detail-card .dc-body { color: var(--text-secondary); font-size: 0.92rem; line-height: 2; letter-spacing: 0.5px; }
.detail-card .dc-body p + p { margin-top: 12px; }

/* 逐行解析表 */
.line-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
.line-table td { padding: 10px 12px; border-bottom: 1px solid rgba(201,169,110,0.08); vertical-align: top; }
.line-table .lt-line {
  font-family: var(--font-poetry); color: var(--moon-gold); white-space: nowrap;
  font-size: 0.92rem; letter-spacing: 1px; width: 1%;
}
.line-table .lt-explain { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.8; }

/* 引用块 */
.insight-quote {
  background: rgba(245,210,122,0.04); border-left: 3px solid var(--moon-gold);
  padding: 16px 22px; border-radius: 0 8px 8px 0; margin-top: 16px;
  font-family: var(--font-poetry); color: var(--text-primary); font-size: 0.95rem;
  letter-spacing: 1.5px; line-height: 1.9;
}
.insight-quote .iq-src { display: block; text-align: right; color: var(--text-muted); font-size: 0.8rem; margin-top: 6px; font-family: var(--font-body); }

/* 滚动揭示 */
.poetry-reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.poetry-reveal.visible { opacity: 1; transform: translateY(0); }

/* 响应式 */
@media (max-width: 1024px) {
  .poetry-hero h1 { font-size: 2rem; letter-spacing: 4px; }
  .detail-card-grid { grid-template-columns: 1fr; }
  .detail-card.full-width { grid-column: span 1; }
  .poem-header .ph-title { font-size: 1.7rem; }
}
@media (max-width: 768px) {
  .poetry-hero { height: 28vh; min-height: 200px; }
  .poetry-hero h1 { font-size: 1.6rem; }
  .poetry-subnav a { padding: 10px 10px; font-size: 0.72rem; letter-spacing: 1px; }
  .poem-full-display { padding: 25px 18px; }
  .poem-full-display .pfd-lines { font-size: 1rem; line-height: 2.2; }
  .poem-header { padding: 25px 18px; }
  .detail-card { padding: 20px 16px; }
  .line-table .lt-line { font-size: 0.82rem; }
  .line-table .lt-explain { font-size: 0.82rem; }
}
</style>
</head>
