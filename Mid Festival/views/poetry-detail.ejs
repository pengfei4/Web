<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="中秋诗词深度赏析">
<title><%= poem.title %> — 月满中华·情系中秋</title>
<link href="/css/common.css" rel="stylesheet">
<link href="/css/animations.css" rel="stylesheet">
<link href="/css/pages.css" rel="stylesheet">
</head>
<body data-journey="poetry-detail">
<div class="page-transition active"><div class="moon-loader"></div></div>

<nav class="navbar">
  <a href="/" class="nav-logo"><div class="logo-icon"></div><span>月满中华</span></a>
  <div class="nav-links">
    <% nav.forEach(function(item) { %>
      <a href="<%= item.href %>"<%= item.href === '/poetry' ? ' class="active"' : '' %>><%= item.label %></a>
    <% }); %>
  </div>
  <div class="nav-toggle"><span></span><span></span><span></span></div>
</nav>
<div class="bg-particles"></div>

<div class="page-content" style="padding-top:100px;">
  <!-- 子导航 -->
  <div class="sub-nav" style="position:sticky;top:70px;z-index:100;background:var(--deep-blue);padding:10px 0;border-bottom:1px solid var(--border-subtle);margin-bottom:30px;">
    <div style="max-width:1200px;margin:0 auto;padding:0 20px;overflow-x:auto;white-space:nowrap;">
      <% allPoems.forEach(function(p) { %>
        <a href="/poetry/<%= p.anchor %>" style="display:inline-block;padding:8px 16px;color:<%= p.anchor === poem.anchor ? 'var(--moon-gold)' : 'var(--text-muted)' %>;text-decoration:none;font-size:0.9rem;"><%= p.short_title %></a>
      <% }); %>
    </div>
  </div>

  <!-- 诗词详情 -->
  <section class="poem-detail-section" id="<%= poem.anchor %>">
    <div class="poem-header">
      <h2 class="ph-title"><%= poem.title %></h2>
      <p class="ph-author"><%= poem.author %></p>
      <p class="ph-dynasty"><%= poem.dynasty_full %></p>
    </div>

    <div class="poem-content-display">
      <div class="pfd-lines"><%- poem.content %></div>
    </div>

    <div class="detail-card">
      <span class="dc-icon">👤</span>
      <h3 class="dc-title">作者生平与文学背景</h3>
      <div class="dc-body"><%- poem.author_bio %></div>
    </div>

    <div class="detail-card">
      <span class="dc-icon">🔍</span>
      <h3 class="dc-title">逐行解析</h3>
      <table class="line-table">
        <% poem.lines.forEach(function(line) { %>
          <tr>
            <td class="lt-line"><%= line.verse_line %></td>
            <td class="lt-explain"><%= line.explanation %></td>
          </tr>
        <% }); %>
      </table>
    </div>

    <div class="detail-card">
      <span class="dc-icon">💛</span>
      <h3 class="dc-title">中秋情感主题</h3>
      <div class="dc-body"><%- poem.theme_analysis %></div>
    </div>

    <div class="detail-card">
      <span class="dc-icon">📜</span>
      <h3 class="dc-title">历史文化背景</h3>
      <div class="dc-body"><%- poem.historical_bg %></div>
    </div>

    <div class="insight-quote">
      "<%= poem.insight_quote %>"
      <span class="iq-src">——<%= poem.quote_source %></span>
    </div>
  </section>
</div>

<footer class="footer">
  <div class="footer-content">
    <div class="footer-links">
      <% nav.forEach(function(item) { %><a href="<%= item.href %>"><%= item.label %></a><% }); %>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-info">
      <p><span class="highlight"><%= config.site_title %></span></p>
      <p><%= config.footer_text %></p>
    </div>
  </div>
</footer>
<div class="back-to-top" title="回到顶部">
  <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
</div>
<script src="/js/common.js"></script>
<script src="/js/moon-journey.js"></script>
<script>MoonJourney.start('poetry-detail');</script>
</body>
</html>
