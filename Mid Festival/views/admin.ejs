<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>管理后台 — 月满中华·情系中秋</title>
<link href="/css/common.css" rel="stylesheet">
<style>
  body { background: var(--deep-blue); color: #e0e0e0; font-family: var(--font-body); }
  .admin-wrap { max-width: 1500px; margin: 0 auto; padding: 100px 20px 40px; }
  .admin-header { text-align: center; margin-bottom: 30px; }
  .admin-header h1 { font-family: var(--font-title); color: var(--moon-gold); font-size: 2rem; margin-bottom: 4px; }
  .admin-header .subtitle { color: var(--text-muted); font-size: 0.9rem; }
  .admin-stats { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; margin-bottom: 30px; }
  .admin-stat { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 20px 28px; text-align: center; min-width: 110px; }
  .admin-stat .num { font-family: var(--font-title); font-size: 2rem; color: var(--moon-gold); }
  .admin-stat .lbl { color: var(--text-muted); font-size: 0.8rem; margin-top: 4px; }
  .toolbar { display: flex; justify-content: center; gap: 12px; margin-bottom: 30px; flex-wrap: wrap; align-items: center; }
  .toolbar input { padding: 10px 20px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle); border-radius: 24px; color: #fff; font-size: 0.9rem; width: 280px; max-width: 50vw; outline: none; }
  .toolbar input:focus { border-color: var(--moon-gold); }
  .toolbar button, .toolbar .btn-sm { padding: 8px 18px; border-radius: 20px; cursor: pointer; font-size: 0.85rem; border: 1px solid var(--border-subtle); background: var(--card-bg); color: var(--text-secondary); transition: all 0.3s; }
  .toolbar button:hover { border-color: var(--moon-gold); color: var(--moon-gold); }
  .table-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 18px; align-items: stretch; }
  .table-card { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 12px; overflow: hidden; transition: border-color 0.3s; display: flex; flex-direction: column; }
  .table-card:hover { border-color: var(--border-glow); }
  .table-card-header { padding: 14px 18px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: rgba(245,210,122,0.02); transition: background 0.3s; }
  .table-card-header:hover { background: rgba(245,210,122,0.06); }
  .table-card-header .tname { font-family: var(--font-title); color: var(--moon-gold); font-size: 1rem; }
  .table-card-header .tmeta { display: flex; align-items: center; gap: 12px; }
  .table-card-header .tcount { color: var(--text-muted); font-size: 0.8rem; }
  .table-card-header .tadd { background: none; border: 1px solid var(--moon-gold); color: var(--moon-gold); border-radius: 14px; padding: 3px 12px; cursor: pointer; font-size: 0.75rem; transition: all 0.3s; }
  .table-card-header .tadd:hover { background: rgba(245,210,122,0.15); }
  .table-card-body { display: none; flex: 1 1 auto; min-height: 0; overflow: auto; border-top: 1px solid var(--border-subtle); scrollbar-width: thin; scrollbar-color: transparent transparent; }
  .table-card:hover .table-card-body { scrollbar-color: rgba(245,210,122,0.35) transparent; }
  .table-card-body::-webkit-scrollbar { width: 5px; }
  .table-card-body::-webkit-scrollbar-thumb { background: transparent; border-radius: 3px; transition: background 0.3s; }
  .table-card-body::-webkit-scrollbar-track { background: transparent; }
  .table-card:hover .table-card-body::-webkit-scrollbar-thumb { background: rgba(245,210,122,0.35); }
  .table-card:hover .table-card-body::-webkit-scrollbar-thumb:hover { background: rgba(245,210,122,0.6); }
  .table-card.open .table-card-body { display: block; }
  .data-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .data-table th { background: rgba(245,210,122,0.06); color: var(--moon-gold); padding: 8px 10px; text-align: left; position: sticky; top: 0; white-space: nowrap; font-weight: normal; }
  .data-table td { padding: 5px 10px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text-secondary); max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .data-table tr:hover td { background: rgba(245,210,122,0.02); }
  .data-table .actions { white-space: nowrap; }
  .data-table .actions button { background: none; border: 1px solid var(--border-subtle); color: var(--text-muted); border-radius: 10px; padding: 2px 10px; cursor: pointer; font-size: 0.72rem; transition: all 0.3s; margin-right: 4px; }
  .data-table .actions .btn-edit:hover { border-color: var(--moon-gold); color: var(--moon-gold); }
  .data-table .actions .btn-del:hover { border-color: var(--warm-orange); color: var(--warm-orange); }
  .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); }
  .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center; }
  .modal-overlay.active { display: flex; }
  .modal { background: #141832; border: 1px solid var(--border-glow); border-radius: 14px; padding: 30px; width: 520px; max-width: 90vw; max-height: 80vh; overflow-y: auto; }
  .modal h3 { color: var(--moon-gold); font-family: var(--font-title); margin-bottom: 20px; font-size: 1.2rem; }
  .modal .field { margin-bottom: 14px; }
  .modal .field label { display: block; color: var(--text-muted); font-size: 0.8rem; margin-bottom: 4px; }
  .modal .field input, .modal .field textarea { width: 100%; padding: 10px 14px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle); border-radius: 8px; color: #fff; font-size: 0.9rem; outline: none; box-sizing: border-box; }
  .modal .field textarea { min-height: 80px; resize: vertical; }
  .modal .field input:focus, .modal .field textarea:focus { border-color: var(--moon-gold); }
  .modal .actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 20px; }
  .modal .actions button { padding: 10px 24px; border-radius: 20px; cursor: pointer; font-size: 0.9rem; border: 1px solid var(--border-subtle); transition: all 0.3s; }
  .modal .actions .btn-save { background: var(--moon-gold); color: #0a0e27; border-color: var(--moon-gold); font-weight: bold; }
  .modal .actions .btn-save:hover { box-shadow: 0 0 15px rgba(245,210,122,0.3); }
  .modal .actions .btn-cancel { background: transparent; color: var(--text-muted); }
  .modal .actions .btn-cancel:hover { color: #fff; }
  .toast { position: fixed; bottom: 30px; right: 30px; z-index: 99999; padding: 12px 24px; border-radius: 8px; font-size: 0.9rem; animation: fadeInUp 0.3s ease; display: none; }
  .toast.success { background: #1a3a2a; border: 1px solid #4caf84; color: #4caf84; }
  .toast.error { background: #3a1a1a; border: 1px solid #e8734a; color: #e8734a; }
  .back-link { display: inline-block; color: var(--text-muted); text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
  .back-link:hover { color: var(--moon-gold); }
  .btn-manage-users { display: inline-block; padding: 10px 28px; background: rgba(245,210,122,0.1); border: 1px solid var(--moon-gold); border-radius: 24px; color: var(--moon-gold); text-decoration: none; font-size: 0.9rem; transition: all 0.3s; }
  .btn-manage-users:hover { background: rgba(245,210,122,0.2); box-shadow: 0 0 20px rgba(245,210,122,0.2); }
  .nav-bar { background: rgba(10,14,39,0.95); border-bottom: 1px solid var(--border-subtle); position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; }
  .nav-bar .logo { font-family: var(--font-title); color: var(--moon-gold); text-decoration: none; font-size: 1.2rem; }
  .nav-bar .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-bar .nav-right a { color: var(--text-muted); text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
  .nav-bar .nav-right a:hover { color: var(--moon-gold); }
  .nav-bar .user-badge { color: var(--moon-gold); font-size: 0.85rem; }
  @media (max-width: 768px) {
    .table-list { grid-template-columns: 1fr; }
    .admin-stats { gap: 12px; }
    .admin-stat { padding: 12px 16px; min-width: 80px; }
    .admin-stat .num { font-size: 1.4rem; }
    .data-table { font-size: 0.7rem; }
    .data-table th, .data-table td { padding: 3px 5px; }
  }
</style>
</head>
<body>

<div class="nav-bar">
  <a href="/" class="logo">🌙 月满中华</a>
  <div class="nav-right">
    <span class="user-badge">👤 <%= user.username %> <span style="color:#c9a44a;">[管理员]</span></span>
    <a href="/">首页</a>
    <a href="/logout">退出</a>
  </div>
</div>

<div class="admin-wrap">
  <div class="admin-header">
    <p><a href="/" class="back-link">← 返回首页</a></p>
    <h1>⚙ 管理后台</h1>
    <p class="subtitle">数据管理 · <%= tables.length %> 张表</p>
    <p style="margin-top:16px;"><a href="/admin/users" class="btn-manage-users">👥 用户账号管理</a></p>
  </div>

  <div class="admin-stats">
    <% var totalRows = 0; Object.values(tableData).forEach(function(d) { totalRows += d.count; }); %>
    <div class="admin-stat"><div class="num"><%= tables.length %></div><div class="lbl">数据表</div></div>
    <div class="admin-stat"><div class="num"><%= totalRows %></div><div class="lbl">总记录</div></div>
    <div class="admin-stat"><div class="num">admin</div><div class="lbl">当前角色</div></div>
  </div>

  <div class="toolbar">
    <input type="text" id="tableSearch" placeholder="搜索数据表..." oninput="filterTables()">
    <button onclick="expandAll()">展开全部</button>
    <button onclick="collapseAll()">收起全部</button>
  </div>

  <div class="table-list" id="tableList">
    <% tables.forEach(function(tname) { var d = tableData[tname]; %>
      <div class="table-card" data-name="<%= tname %>">
        <div class="table-card-header" onclick="event.stopPropagation(); toggleRow(this.parentElement)">
          <span class="tname"><%= tname %></span>
          <div class="tmeta">
            <span class="tcount"><%= d ? d.count : 0 %> 条</span>
            <button class="tadd" onclick="event.stopPropagation(); openCreate('<%= tname %>', <%= JSON.stringify(d ? d.columns : []) %>)" title="新增记录">+ 新增</button>
          </div>
        </div>
        <div class="table-card-body">
          <% if (d && d.rows.length > 0) { %>
            <table class="data-table">
              <thead><tr>
                <% d.columns.forEach(function(col) { %><th><%= col %></th><% }); %>
                <th style="width:80px;">操作</th>
              </tr></thead>
              <tbody>
                <% d.rows.forEach(function(row) { %>
                  <tr data-id="<%= row.id %>">
                    <% d.columns.forEach(function(col) { %><td title="<%= String(row[col] || '').replace(/"/g, '&quot;') %>"><%= String(row[col] || '') %></td><% }); %>
                    <td class="actions">
                      <button class="btn-edit" onclick="openEdit('<%= tname %>', <%= JSON.stringify(row.id) %>, <%= JSON.stringify(d.columns) %>, <%= JSON.stringify(d.columns.map(function(c){return String(row[c]||'')})) %>)">编辑</button>
                      <button class="btn-del" onclick="deleteRow('<%= tname %>', <%= row.id %>)">删除</button>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="empty-state"><p>暂无数据</p></div>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
  <div class="modal" onclick="event.stopPropagation()">
    <h3 id="modalTitle">编辑记录</h3>
    <div id="modalFields"></div>
    <div class="actions">
      <button class="btn-cancel" onclick="closeModal()">取消</button>
      <button class="btn-save" id="btnSave" onclick="saveRecord()">保存</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
var currentTable = '';
var currentId = null;
var currentColumns = [];

function filterTables() {
  var q = document.getElementById('tableSearch').value.toLowerCase();
  document.querySelectorAll('.table-card').forEach(function(card) {
    card.style.display = q ? (card.dataset.name.toLowerCase().indexOf(q) >= 0 ? '' : 'none') : '';
  });
}
function expandAll() { document.querySelectorAll('.table-card').forEach(function(c) { c.classList.add('open'); }); }
function collapseAll() { document.querySelectorAll('.table-card').forEach(function(c) { c.classList.remove('open'); }); }

function toggleRow(card) {
  var rect = card.getBoundingClientRect();
  var rowTop = Math.round(rect.top);
  var isOpening = !card.classList.contains('open');
  var allCards = document.querySelectorAll('.table-card');
  allCards.forEach(function(c) {
    if (c.style.display === 'none') return;
    var r = Math.round(c.getBoundingClientRect().top);
    if (Math.abs(r - rowTop) < 3) {
      if (isOpening) { c.classList.add('open'); }
      else { c.classList.remove('open'); }
    }
  });
}

function showToast(msg, type) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + type;
  t.style.display = 'block';
  setTimeout(function() { t.style.display = 'none'; }, 3000);
}

function findCard(table) {
  return document.querySelector('.table-card[data-name="' + table + '"]');
}

function escapeHtml(str) {
  var div = document.createElement('div');
  div.appendChild(document.createTextNode(str));
  return div.innerHTML;
}

function updateStats(delta) {
  var statEl = document.querySelector('.admin-stat:nth-child(2) .num');
  if (statEl) { statEl.textContent = parseInt(statEl.textContent) + delta; }
}

function updateCardCount(card, delta) {
  var countEl = card.querySelector('.tcount');
  if (countEl) { countEl.textContent = (parseInt(countEl.textContent) + delta) + ' 条'; }
}

function openCreate(table, columns) {
  currentTable = table;
  currentId = null;
  currentColumns = columns;
  document.getElementById('modalTitle').textContent = '新增记录 — ' + table;
  var html = '';
  columns.forEach(function(col) {
    if (col === 'id') return;
    html += '<div class="field"><label>' + col + '</label>';
    html += '<input type="text" id="field_' + col + '" placeholder="' + col + '">';
    html += '</div>';
  });
  document.getElementById('modalFields').innerHTML = html;
  document.getElementById('modalOverlay').classList.add('active');
}

function openEdit(table, id, columns, values) {
  currentTable = table;
  currentId = id;
  currentColumns = columns;
  document.getElementById('modalTitle').textContent = '编辑记录 #' + id + ' — ' + table;
  var html = '';
  columns.forEach(function(col, i) {
    html += '<div class="field"><label>' + col + '</label>';
    if (col === 'id') {
      html += '<input type="number" step="1" id="field_' + col + '" value="' + (values[i] || '') + '" onchange="validateIdField(this)">';
    } else {
      html += '<input type="text" id="field_' + col + '" value="' + (values[i] || '').replace(/"/g, '&quot;') + '">';
    }
    html += '</div>';
  });
  document.getElementById('modalFields').innerHTML = html;
  document.getElementById('modalOverlay').classList.add('active');
}

function validateIdField(el) {
  var val = el.value.trim();
  if (val !== '' && !/^-?\d+$/.test(val)) {
    showToast('请输入整数', 'error');
    el.value = '';
    el.focus();
  }
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('active');
}

function saveRecord() {
  var cols = [];
  var vals = [];
  currentColumns.forEach(function(col) {
    if (col === 'id') return;
    var el = document.getElementById('field_' + col);
    if (el) { cols.push(col); vals.push(el.value); }
  });
  if (cols.length === 0) return showToast('没有可保存的字段', 'error');

  var url = '/api/admin/table/' + currentTable;
  var method = 'POST';
  if (currentId) { url += '/' + currentId; method = 'PUT'; }

  fetch(url, {
    method: method,
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ columns: cols, values: vals })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) {
      var card = findCard(currentTable);
      if (currentId) {
        // 更新：找到对应行并更新单元格
        var row = card.querySelector('.data-table tbody tr[data-id="' + currentId + '"]');
        if (row) {
          var cells = row.querySelectorAll('td');
          currentColumns.forEach(function(col, i) {
            if (i < cells.length) {
              var val = vals[currentColumns.indexOf(col)];
              cells[i].textContent = val || '';
              cells[i].setAttribute('title', val || '');
            }
          });
          // 更新编辑按钮的 onclick 参数
          var editBtn = row.querySelector('.btn-edit');
          if (editBtn) {
            var valsJson = JSON.stringify(vals).replace(/"/g, '&quot;');
            var colsJson = JSON.stringify(currentColumns).replace(/"/g, '&quot;');
            editBtn.setAttribute('onclick', 'openEdit(\'' + currentTable + '\', ' + currentId + ', ' + colsJson + ', ' + valsJson + ')');
          }
        }
        showToast('更新成功', 'success');
      } else {
        // 创建：在表格中插入新行
        var newId = data.id;
        var tbody = card.querySelector('.data-table tbody');
        var emptyState = card.querySelector('.empty-state');
        if (emptyState) {
          // 之前没有数据，需要创建表格结构
          var tableHtml = '<table class="data-table"><thead><tr>';
          currentColumns.forEach(function(col) { tableHtml += '<th>' + col + '</th>'; });
          tableHtml += '<th style="width:80px;">操作</th></tr></thead><tbody></tbody></table>';
          emptyState.parentElement.innerHTML = tableHtml;
          tbody = card.querySelector('.data-table tbody');
        }
        var tr = document.createElement('tr');
        tr.setAttribute('data-id', newId);
        currentColumns.forEach(function(col) {
          var td = document.createElement('td');
          var val = vals[currentColumns.indexOf(col)];
          td.textContent = val || '';
          td.setAttribute('title', val || '');
          tr.appendChild(td);
        });
        var actionsTd = document.createElement('td');
        actionsTd.className = 'actions';
        var colsJson = JSON.stringify(currentColumns).replace(/"/g, '&quot;');
        var valsJson = JSON.stringify(vals).replace(/"/g, '&quot;');
        actionsTd.innerHTML = '<button class="btn-edit" onclick="openEdit(\'' + currentTable + '\', ' + newId + ', ' + colsJson + ', ' + valsJson + ')">编辑</button> <button class="btn-del" onclick="deleteRow(\'' + currentTable + '\', ' + newId + ')">删除</button>';
        tr.appendChild(actionsTd);
        if (tbody) { tbody.appendChild(tr); }
        updateCardCount(card, 1);
        updateStats(1);
        showToast('创建成功', 'success');
      }
      closeModal();
    } else {
      showToast('操作失败: ' + (data.error || '未知错误'), 'error');
    }
  }).catch(function(e) {
    showToast('网络错误: ' + e.message, 'error');
  });
}

function deleteRow(table, id) {
  if (!confirm('确定要删除 ' + table + ' 表中 id=' + id + ' 的记录吗？此操作不可撤销。')) return;
  fetch('/api/admin/table/' + table + '/' + id, { method: 'DELETE' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        var card = findCard(table);
        var row = card.querySelector('.data-table tbody tr[data-id="' + id + '"]');
        if (row) {
          var tbody = row.parentElement;
          row.remove();
          updateCardCount(card, -1);
          updateStats(-1);
          // 如果表格为空，显示空状态
          if (tbody.querySelectorAll('tr').length === 0) {
            var tableEl = card.querySelector('.data-table');
            if (tableEl) {
              tableEl.outerHTML = '<div class="empty-state"><p>暂无数据</p></div>';
            }
          }
        }
        showToast('删除成功', 'success');
      } else {
        showToast('删除失败: ' + (data.error || '未知错误'), 'error');
      }
    }).catch(function(e) {
      showToast('网络错误: ' + e.message, 'error');
    });
}
</script>
</body>
</html>
