</div>

<script src="/js/common.js"></script>
<script src="/js/moon-journey.js"></script>
<script>MoonJourney.start('poetry');</script>
<script>
(function() {
  var grid = document.querySelector('.poetry-grid-new');
  if (!grid) return;

  function getColCount() {
    var w = window.innerWidth;
    if (w <= 550) return 1;
    if (w <= 900) return 2;
    if (w <= 1200) return 3;
    return 4;
  }

  var lastColCount = 0;

  function redistribute() {
    var cols = getColCount();
    if (cols === lastColCount) return;
    lastColCount = cols;

    var cards = Array.from(grid.querySelectorAll('.poem-card'));

    // Remove old column wrappers
    grid.querySelectorAll('.poetry-col').forEach(function(c) { c.remove(); });

    // Create new columns
    var columns = [];
    for (var i = 0; i < cols; i++) {
      var col = document.createElement('div');
      col.className = 'poetry-col';
      grid.appendChild(col);
      columns.push(col);
    }

    // Distribute cards sequentially (preserves reading order)
    cards.forEach(function(card, i) {
      columns[i % cols].appendChild(card);
    });
  }

  redistribute();

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(redistribute, 200);
  });
})();
</script>
</body>
</html>
