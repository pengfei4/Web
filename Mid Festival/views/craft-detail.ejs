<style>
/* ============================================================
   匠心手作详情页
   ============================================================ */
.craft-hero {
  position: relative;
  height: 38vh;
  min-height: 280px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(10,14,39,0.3) 0%, rgba(10,14,39,0.6) 50%, var(--deep-blue) 100%);
}
.craft-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 30%, rgba(245,210,122,0.1) 0%, transparent 55%),
              radial-gradient(ellipse at 30% 60%, rgba(232,115,74,0.06) 0%, transparent 40%);
  pointer-events: none;
}
.craft-hero .hero-content { text-align: center; position: relative; z-index: 2; animation: fadeInUp 0.8s ease; }
.craft-hero h1 {
  font-family: var(--font-title); font-size: 2.8rem; color: var(--moon-gold);
  letter-spacing: 6px; margin-bottom: 8px; text-shadow: 0 0 40px rgba(245,210,122,0.3);
}
.craft-hero .hero-desc { font-family: var(--font-poetry); font-size: 1.15rem; color: var(--text-secondary); letter-spacing: 3px; }

/* 子导航 */
.craft-subnav {
  position: sticky; top: 70px; z-index: 998;
  background: rgba(10,14,39,0.92); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border-subtle); overflow-x: auto;
  scrollbar-width: none;
}
.craft-subnav::-webkit-scrollbar { display: none; }
.craft-subnav-inner {
  display: flex; gap: 0; max-width: 1100px; margin: 0 auto; padding: 0 10px;
  justify-content: center;
}
.craft-subnav a {
  flex-shrink: 0; padding: 13px 16px; color: var(--text-secondary);
  font-family: var(--font-title); font-size: 0.82rem; letter-spacing: 1.5px;
  border-bottom: 2px solid transparent; transition: all 0.3s ease; text-decoration: none; white-space: nowrap;
}
.craft-subnav a:hover, .craft-subnav a.active { color: var(--moon-gold); border-bottom-color: var(--moon-gold); }

/* 内容区 */
.craft-content { max-width: 1000px; margin: 0 auto; padding: 50px 20px 80px; }

/* 步骤详情节 */
.craft-detail-section { padding: 60px 0; border-bottom: 1px solid var(--border-subtle); }
.craft-detail-section:last-child { border-bottom: none; }

/* 步骤头部 */
.craft-step-header {
  text-align: center; margin-bottom: 40px; padding: 35px;
  background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 16px;
}
.craft-step-header .csh-icon {
  font-size: 4rem; display: block; margin-bottom: 12px;
}
.craft-step-header .csh-step-num {
  display: inline-block; padding: 3px 14px;
  border: 1px solid rgba(201,169,110,0.3); border-radius: 12px;
  font-size: 0.78rem; color: var(--text-muted); letter-spacing: 2px; margin-bottom: 8px;
}
.craft-step-header .csh-title {
  font-family: var(--font-title); font-size: 2.2rem; color: var(--moon-gold);
  letter-spacing: 5px; margin-bottom: 8px;
}
.craft-step-header .csh-subtitle {
  font-family: var(--font-poetry); font-size: 1rem; color: var(--text-secondary); letter-spacing: 2px;
}

/* 流程图示 */
.craft-flow-visual {
  background: linear-gradient(135deg, rgba(20,24,54,0.8), rgba(26,31,74,0.7));
  border: 1px solid var(--border-subtle); border-radius: 14px;
  padding: 40px; text-align: center; margin-bottom: 30px;
}
.craft-flow-visual .cfv-icon-lg { font-size: 5rem; display: block; margin-bottom: 15px; }
.craft-flow-visual .cfv-tagline {
  font-family: var(--font-poetry); font-size: 1.2rem; color: var(--text-primary);
  letter-spacing: 2px; line-height: 2;
}

/* 内容卡片网格 */
.detail-card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 20px; }
.detail-card {
  background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 12px;
  padding: 28px; transition: all 0.35s ease;
}
.detail-card:hover { border-color: var(--border-glow); box-shadow: 0 4px 20px rgba(245,210,122,0.08); }
.detail-card.full-width { grid-column: span 2; }
.detail-card .dc-label {
  display: flex; align-items: center; gap: 10px; margin-bottom: 16px; padding-bottom: 14px;
  border-bottom: 1px solid rgba(201,169,110,0.15);
}
.dc-label .dc-icon { font-size: 1.6rem; }
.dc-label .dc-title { font-family: var(--font-title); font-size: 1.15rem; color: var(--moon-gold); letter-spacing: 2px; }
.detail-card .dc-body { color: var(--text-secondary); font-size: 0.92rem; line-height: 2; letter-spacing: 0.5px; }
.detail-card .dc-body p + p { margin-top: 12px; }

/* 要点列表 */
.key-points { list-style: none; padding: 0; }
.key-points li {
  position: relative; padding-left: 22px; margin-bottom: 10px;
  color: var(--text-secondary); font-size: 0.92rem; line-height: 1.8;
}
.key-points li::before {
  content: '◆'; position: absolute; left: 0; top: 0;
  color: var(--moon-gold); font-size: 0.5rem; line-height: 2;
}

/* 引用块 */
.insight-quote {
  background: rgba(245,210,122,0.04); border-left: 3px solid var(--moon-gold);
  padding: 16px 22px; border-radius: 0 8px 8px 0; margin-top: 16px;
  font-family: var(--font-poetry); color: var(--text-primary); font-size: 0.95rem;
  letter-spacing: 1.5px; line-height: 1.9;
}
.insight-quote .iq-src { display: block; text-align: right; color: var(--text-muted); font-size: 0.8rem; margin-top: 6px; font-family: var(--font-body); }

/* 滚动揭示 */
.craft-reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.craft-reveal.visible { opacity: 1; transform: translateY(0); }

/* 响应式 */
@media (max-width: 1024px) {
  .craft-hero h1 { font-size: 2rem; letter-spacing: 4px; }
  .detail-card-grid { grid-template-columns: 1fr; }
  .detail-card.full-width { grid-column: span 1; }
  .craft-step-header .csh-title { font-size: 1.7rem; }
}
@media (max-width: 768px) {
  .craft-hero { height: 28vh; min-height: 200px; }
  .craft-hero h1 { font-size: 1.6rem; }
  .craft-subnav a { padding: 10px 10px; font-size: 0.72rem; letter-spacing: 1px; }
  .craft-flow-visual { padding: 25px 18px; }
  .craft-flow-visual .cfv-icon-lg { font-size: 3.5rem; }
  .craft-step-header { padding: 25px 18px; }
  .detail-card { padding: 20px 16px; }
}
</style>
