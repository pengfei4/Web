<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>用户账号管理 — 管理后台</title>
<link href="/css/common.css" rel="stylesheet">
<style>
  body { background: var(--deep-blue); color: #e0e0e0; font-family: var(--font-body); }
  .admin-wrap { max-width: 1100px; margin: 0 auto; padding: 100px 20px 40px; }
  .admin-header { text-align: center; margin-bottom: 30px; }
  .admin-header h1 { font-family: var(--font-title); color: var(--moon-gold); font-size: 2rem; margin-bottom: 4px; }
  .admin-header .subtitle { color: var(--text-muted); font-size: 0.9rem; }

  .toolbar { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
  .toolbar input { padding: 10px 20px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle); border-radius: 24px; color: #fff; font-size: 0.9rem; width: 280px; outline: none; }
  .toolbar input:focus { border-color: var(--moon-gold); }
  .btn { padding: 10px 22px; border-radius: 22px; cursor: pointer; font-size: 0.85rem; border: 1px solid var(--border-subtle); transition: all 0.3s; text-decoration: none; display: inline-block; }
  .btn-primary { background: var(--moon-gold); color: #0a0e27; border-color: var(--moon-gold); font-weight: bold; }
  .btn-primary:hover { box-shadow: 0 0 15px rgba(245,210,122,0.3); }
  .btn-outline { background: transparent; color: var(--text-muted); }
  .btn-outline:hover { border-color: var(--moon-gold); color: var(--moon-gold); }

  .user-table-wrap { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 12px; overflow: hidden; }
  .user-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  .user-table th { background: rgba(245,210,122,0.06); color: var(--moon-gold); padding: 12px 16px; text-align: left; font-weight: normal; white-space: nowrap; }
  .user-table td { padding: 10px 16px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text-secondary); }
  .user-table tbody tr:hover td { background: rgba(245,210,122,0.02); }
  .user-table .actions { white-space: nowrap; text-align: right; }
  .user-table .actions button { background: none; border: 1px solid var(--border-subtle); color: var(--text-muted); border-radius: 10px; padding: 4px 12px; cursor: pointer; font-size: 0.78rem; transition: all 0.3s; margin-left: 6px; }
  .user-table .actions .btn-edit:hover { border-color: var(--moon-gold); color: var(--moon-gold); }
  .user-table .actions .btn-pwd:hover { border-color: #5b9bd5; color: #5b9bd5; }
  .user-table .actions .btn-del:hover { border-color: var(--warm-orange); color: var(--warm-orange); }
  .role-badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 0.75rem; }
  .role-badge.admin { background: rgba(245,210,122,0.15); color: var(--moon-gold); }
  .role-badge.user { background: rgba(255,255,255,0.06); color: var(--text-secondary); }
  .empty-state { text-align: center; padding: 50px 20px; color: var(--text-muted); }

  .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center; }
  .modal-overlay.active { display: flex; }
  .modal { background: #141832; border: 1px solid var(--border-glow); border-radius: 14px; padding: 30px; width: 460px; max-width: 90vw; max-height: 80vh; overflow-y: auto; }
  .modal h3 { color: var(--moon-gold); font-family: var(--font-title); margin-bottom: 20px; font-size: 1.2rem; }
  .modal .field { margin-bottom: 14px; }
  .modal .field label { display: block; color: var(--text-muted); font-size: 0.8rem; margin-bottom: 4px; }
  .modal .field input, .modal .field select { width: 100%; padding: 10px 14px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle); border-radius: 8px; color: #fff; font-size: 0.9rem; outline: none; box-sizing: border-box; }
  .modal .field select { cursor: pointer; appearance: none; }
  .modal .field select option { background: #141832; color: #fff; }
  .modal .field input:focus, .modal .field select:focus { border-color: var(--moon-gold); }
  .modal .actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 20px; }
  .modal .actions button { padding: 10px 24px; border-radius: 20px; cursor: pointer; font-size: 0.9rem; border: 1px solid var(--border-subtle); transition: all 0.3s; }
  .modal .actions .btn-save { background: var(--moon-gold); color: #0a0e27; border-color: var(--moon-gold); font-weight: bold; }
  .modal .actions .btn-save:hover { box-shadow: 0 0 15px rgba(245,210,122,0.3); }
  .modal .actions .btn-cancel { background: transparent; color: var(--text-muted); }
  .modal .actions .btn-cancel:hover { color: #fff; }
  .modal .hint { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; }

  .toast { position: fixed; bottom: 30px; right: 30px; z-index: 99999; padding: 12px 24px; border-radius: 8px; font-size: 0.9rem; animation: fadeInUp 0.3s ease; display: none; }
  .toast.success { background: #1a3a2a; border: 1px solid #4caf84; color: #4caf84; }
  .toast.error { background: #3a1a1a; border: 1px solid #e8734a; color: #e8734a; }

  .back-link { display: inline-block; color: var(--text-muted); text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
  .back-link:hover { color: var(--moon-gold); }

  .nav-bar { background: rgba(10,14,39,0.95); border-bottom: 1px solid var(--border-subtle); position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; }
  .nav-bar .logo { font-family: var(--font-title); color: var(--moon-gold); text-decoration: none; font-size: 1.2rem; }
  .nav-bar .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-bar .nav-right a { color: var(--text-muted); text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
  .nav-bar .nav-right a:hover { color: var(--moon-gold); }
  .nav-bar .user-badge { color: var(--moon-gold); font-size: 0.85rem; }

  .stats-bar { display: flex; justify-content: center; gap: 24px; margin-bottom: 24px; }
  .stat-item { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 10px; padding: 14px 24px; text-align: center; min-width: 80px; }
  .stat-item .num { font-family: var(--font-title); font-size: 1.5rem; color: var(--moon-gold); }
  .stat-item .lbl { color: var(--text-muted); font-size: 0.75rem; margin-top: 2px; }

  @media (max-width: 768px) {
    .toolbar { flex-direction: column; align-items: stretch; }
    .toolbar input { width: 100%; }
    .user-table { font-size: 0.75rem; }
    .user-table th, .user-table td { padding: 8px 10px; }
  }
</style>
</head>
<body>

<div class="nav-bar">
  <a href="/" class="logo">🌙 月满中华</a>
  <div class="nav-right">
    <span class="user-badge">👤 <%= user.username %> <span style="color:#c9a44a;">[管理员]</span></span>
    <a href="/admin">数据管理</a>
    <a href="/">首页</a>
    <a href="/logout">退出</a>
  </div>
</div>

<div class="admin-wrap">
  <div class="admin-header">
    <p>
      <a href="/admin" class="back-link">← 返回数据管理</a>
    </p>
    <h1>👥 用户账号管理</h1>
    <p class="subtitle">管理网站注册用户 · 共 <%= users.length %> 个账号</p>
  </div>

  <div class="stats-bar">
    <div class="stat-item"><div class="num" id="totalUsers"><%= users.length %></div><div class="lbl">总用户数</div></div>
    <div class="stat-item"><div class="num" id="adminCount"><%= users.filter(function(u){return u.role==='admin'}).length %></div><div class="lbl">管理员</div></div>
    <div class="stat-item"><div class="num" id="userCount"><%= users.filter(function(u){return u.role==='user'}).length %></div><div class="lbl">普通用户</div></div>
  </div>

  <div class="toolbar">
    <input type="text" id="userSearch" placeholder="🔍 搜索用户名..." oninput="filterUsers()">
    <div style="display:flex;gap:10px;">
      <button class="btn btn-outline" onclick="refreshList()">刷新列表</button>
      <button class="btn btn-primary" onclick="openCreate()">+ 新增用户</button>
    </div>
  </div>

  <div class="user-table-wrap">
    <% if (users.length > 0) { %>
      <table class="user-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>用户名</th>
            <th>角色</th>
            <th>注册时间</th>
            <th style="text-align:right;">操作</th>
          </tr>
        </thead>
        <tbody id="userTableBody">
          <% users.forEach(function(u) { %>
            <tr data-id="<%= u.id %>" data-username="<%= u.username %>">
              <td><%= u.id %></td>
              <td class="uname"><%= u.username %></td>
              <td><span class="role-badge <%= u.role %>"><%= u.role === 'admin' ? '管理员' : '普通用户' %></span></td>
              <td><%= u.created_at %></td>
              <td class="actions">
                <% if (u.role === 'admin' && adminCount <= 1) { %>
                  <span style="color:var(--text-muted);font-size:0.75rem;">唯一管理员 · 受保护</span>
                <% } else { %>
                  <button class="btn-edit" onclick="openEdit(<%= u.id %>, '<%= u.username %>', '<%= u.role %>')">编辑</button>
                  <button class="btn-pwd" onclick="openChangePwd(<%= u.id %>, '<%= u.username %>')">改密</button>
                  <% if (u.id !== user.id) { %>
                    <button class="btn-del" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')">删除</button>
                  <% } %>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <div class="empty-state"><p>暂无用户数据</p></div>
    <% } %>
  </div>
</div>

<!-- 新增/编辑用户 Modal -->
<div class="modal-overlay" id="modalUser" onclick="closeModal('modalUser')">
  <div class="modal" onclick="event.stopPropagation()">
    <h3 id="modalUserTitle">新增用户</h3>
    <input type="hidden" id="editUserId">
    <div class="field">
      <label>用户名</label>
      <input type="text" id="editUsername" placeholder="请输入用户名（2-20字符）" maxlength="20">
    </div>
    <div class="field" id="pwdField">
      <label>密码</label>
      <input type="text" id="editPassword" placeholder="请输入密码（至少4位）">
      <div class="hint">密码将明文存储，请使用临时密码并提醒用户自行修改</div>
    </div>
    <div class="field">
      <label>角色</label>
      <select id="editRole">
        <option value="user">普通用户 (user)</option>
        <option value="admin">管理员 (admin)</option>
      </select>
    </div>
    <div class="actions">
      <button class="btn-cancel" onclick="closeModal('modalUser')">取消</button>
      <button class="btn-save" onclick="saveUser()">保存</button>
    </div>
  </div>
</div>

<!-- 修改密码 Modal -->
<div class="modal-overlay" id="modalPwd" onclick="closeModal('modalPwd')">
  <div class="modal" onclick="event.stopPropagation()">
    <h3 id="modalPwdTitle">修改密码</h3>
    <input type="hidden" id="pwdUserId">
    <div class="field">
      <label>新密码</label>
      <input type="text" id="newPassword" placeholder="请输入新密码（至少4位）">
      <div class="hint">密码将明文存储，修改后请提醒用户</div>
    </div>
    <div class="actions">
      <button class="btn-cancel" onclick="closeModal('modalPwd')">取消</button>
      <button class="btn-save" onclick="savePassword()">确认修改</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
var currentUserId = null;
var currentAdminId = <%= user.id %>;
var adminCount = <%= adminCount %>;

function filterUsers() {
  var q = document.getElementById('userSearch').value.toLowerCase();
  document.querySelectorAll('#userTableBody tr').forEach(function(tr) {
    tr.style.display = q ? (tr.dataset.username.toLowerCase().indexOf(q) >= 0 ? '' : 'none') : '';
  });
}

function showToast(msg, type) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + type;
  t.style.display = 'block';
  clearTimeout(t._timer);
  t._timer = setTimeout(function() { t.style.display = 'none'; }, 3000);
}

function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}

function openCreate() {
  currentUserId = null;
  document.getElementById('modalUserTitle').textContent = '新增用户';
  document.getElementById('editUserId').value = '';
  document.getElementById('editUsername').value = '';
  document.getElementById('editPassword').value = '';
  document.getElementById('editRole').value = 'user';
  document.getElementById('pwdField').style.display = '';
  document.getElementById('modalUser').classList.add('active');
}

function openEdit(id, username, role) {
  currentUserId = id;
  document.getElementById('modalUserTitle').textContent = '编辑用户 #' + id;
  document.getElementById('editUserId').value = id;
  document.getElementById('editUsername').value = username;
  document.getElementById('editRole').value = role;
  document.getElementById('pwdField').style.display = 'none';
  document.getElementById('modalUser').classList.add('active');
}

function openChangePwd(id, username) {
  document.getElementById('modalPwdTitle').textContent = '修改密码 — ' + username;
  document.getElementById('pwdUserId').value = id;
  document.getElementById('newPassword').value = '';
  document.getElementById('modalPwd').classList.add('active');
}

function saveUser() {
  var username = document.getElementById('editUsername').value.trim();
  var role = document.getElementById('editRole').value;
  if (!username) return showToast('请输入用户名', 'error');
  if (username.length < 2) return showToast('用户名至少需要2个字符', 'error');

  var isCreate = !currentUserId;
  if (isCreate) {
    var password = document.getElementById('editPassword').value;
    if (!password || password.length < 4) return showToast('密码至少需要4位', 'error');
    fetch('/api/admin/users', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: username, password: password, role: role })
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.success) {
        showToast('用户创建成功', 'success');
        closeModal('modalUser');
        refreshList();
      } else {
        showToast('创建失败: ' + (data.error || '未知错误'), 'error');
      }
    }).catch(function(e) {
      showToast('网络错误: ' + e.message, 'error');
    });
  } else {
    fetch('/api/admin/users/' + currentUserId, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: username, role: role })
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.success) {
        showToast('用户信息更新成功', 'success');
        closeModal('modalUser');
        refreshList();
      } else {
        showToast('更新失败: ' + (data.error || '未知错误'), 'error');
      }
    }).catch(function(e) {
      showToast('网络错误: ' + e.message, 'error');
    });
  }
}

function savePassword() {
  var id = document.getElementById('pwdUserId').value;
  var password = document.getElementById('newPassword').value;
  if (!password || password.length < 4) return showToast('密码至少需要4位', 'error');
  fetch('/api/admin/users/' + id + '/password', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ password: password })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) {
      showToast('密码修改成功', 'success');
      closeModal('modalPwd');
    } else {
      showToast('修改失败: ' + (data.error || '未知错误'), 'error');
    }
  }).catch(function(e) {
    showToast('网络错误: ' + e.message, 'error');
  });
}

function deleteUser(id, username) {
  if (!confirm('确定要删除用户 "' + username + '" (ID: ' + id + ') 吗？\n\n此操作不可撤销！')) return;
  fetch('/api/admin/users/' + id, { method: 'DELETE' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        showToast('用户已删除', 'success');
        refreshList();
      } else {
        showToast('删除失败: ' + (data.error || '未知错误'), 'error');
      }
    }).catch(function(e) {
      showToast('网络错误: ' + e.message, 'error');
    });
}

function refreshList() {
  fetch('/api/admin/users')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        var users = data.users;
        var tbody = document.getElementById('userTableBody');
        var html = '';
        if (users.length === 0) {
          document.querySelector('.user-table-wrap').innerHTML = '<div class="empty-state"><p>暂无用户数据</p></div>';
        } else {
          users.forEach(function(u) {
            html += '<tr data-id="' + u.id + '" data-username="' + u.username + '">';
            html += '<td>' + u.id + '</td>';
            html += '<td class="uname">' + u.username + '</td>';
            html += '<td><span class="role-badge ' + u.role + '">' + (u.role === 'admin' ? '管理员' : '普通用户') + '</span></td>';
            html += '<td>' + (u.created_at || '') + '</td>';
            html += '<td class="actions">';
            if (u.role === 'admin' && adminCount <= 1) {
              html += '<span style="color:var(--text-muted);font-size:0.75rem;">唯一管理员 · 受保护</span>';
            } else {
              html += '<button class="btn-edit" onclick="openEdit(' + u.id + ', \'' + u.username + '\', \'' + u.role + '\')">编辑</button> ';
              html += '<button class="btn-pwd" onclick="openChangePwd(' + u.id + ', \'' + u.username + '\')">改密</button> ';
              if (u.id !== currentAdminId) {
                html += '<button class="btn-del" onclick="deleteUser(' + u.id + ', \'' + u.username + '\')">删除</button>';
              }
            }
            html += '</td></tr>';
          });
          var wrap = document.querySelector('.user-table-wrap');
          if (!wrap.querySelector('.user-table')) {
            wrap.innerHTML = '<table class="user-table"><thead><tr><th>ID</th><th>用户名</th><th>角色</th><th>注册时间</th><th style="text-align:right;">操作</th></tr></thead><tbody id="userTableBody"></tbody></table>';
            document.getElementById('userTableBody').innerHTML = html;
          } else {
            tbody.innerHTML = html;
          }
        }
        // 更新统计
        document.getElementById('totalUsers').textContent = users.length;
        document.getElementById('adminCount').textContent = users.filter(function(u){return u.role==='admin'}).length;
        document.getElementById('userCount').textContent = users.filter(function(u){return u.role==='user'}).length;
        adminCount = users.filter(function(u){return u.role==='admin'}).length;
        document.querySelector('.subtitle').textContent = '管理网站注册用户 · 共 ' + users.length + ' 个账号';
      }
    }).catch(function(e) {
      showToast('刷新失败: ' + e.message, 'error');
    });
}
</script>
</body>
</html>
