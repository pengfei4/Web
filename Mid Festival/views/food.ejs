<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="中秋美食文化专题——烟火人间·食味中秋，探索千年美食传承">
<title>美食文化 — 月满中华·情系中秋</title>
<link href="/css/common.css" rel="stylesheet">
<link href="/css/animations.css" rel="stylesheet">
<style>
/* ============================================================
   美食文化专题页 — "烟火人间·食味中秋"
   独立的暖色调视觉体系，与深蓝主题完全区分
   ============================================================ */

/* ---- CSS 自定义属性覆盖 ---- */
:root {
  --food-bg-deep: #1a1010;
  --food-bg-mid: #2d0f1a;
  --food-bg-warm: #3a1a15;
  --food-gold: #d4a853;
  --food-amber: #c87941;
  --food-red: #c0392b;
  --food-cream: #f0e0c8;
  --food-cream-dim: #c4b598;
  --food-card-bg: rgba(35, 18, 18, 0.9);
  --food-border: rgba(200, 140, 80, 0.25);
  --food-border-glow: rgba(212, 168, 83, 0.5);
  --food-text: #f0e0c8;
  --food-text-dim: #b8a088;
  --food-text-muted: #8a7060;
}

/* ---- Body 暖色背景覆盖 ---- */
body {
  background: var(--food-bg-deep);
  background-image:
    radial-gradient(ellipse at 50% 15%, #3a1a15 0%, transparent 50%),
    radial-gradient(ellipse at 50% 85%, #2d0f1a 0%, transparent 35%),
    linear-gradient(180deg, var(--food-bg-deep) 0%, #1f0d12 50%, #150a0e 100%);
}

/* ---- 滚动条适配 ---- */
::-webkit-scrollbar-thumb { background: var(--food-amber); }
::-webkit-scrollbar-thumb:hover { background: var(--food-gold); }

/* ---- 页面 Hero ---- */
.food-hero {
  position: relative;
  height: 55vh;
  min-height: 420px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background:
    radial-gradient(ellipse at 50% 30%, rgba(212,168,83,0.15) 0%, transparent 55%),
    radial-gradient(ellipse at 70% 50%, rgba(200,121,65,0.1) 0%, transparent 40%),
    linear-gradient(180deg, #1a1010 0%, #2d0f1a 40%, #1f0d12 100%);
}
.food-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 35%, rgba(255,180,80,0.08) 0%, transparent 40%),
    radial-gradient(circle at 30% 60%, rgba(220,100,40,0.06) 0%, transparent 35%);
  pointer-events: none;
}
.food-hero .hero-steam {
  position: absolute;
  bottom: 15%;
  left: 0;
  width: 100%;
  height: 200px;
  pointer-events: none;
  overflow: hidden;
}
.steam-wisp {
  position: absolute;
  bottom: 0;
  width: 3px;
  background: rgba(240,224,200,0.15);
  border-radius: 50%;
  animation: steamRise 3s ease-out infinite;
}
.steam-wisp:nth-child(1) { left: 15%; animation-delay: 0s; height: 60px; }
.steam-wisp:nth-child(2) { left: 25%; animation-delay: 0.4s; height: 80px; }
.steam-wisp:nth-child(3) { left: 35%; animation-delay: 0.8s; height: 55px; }
.steam-wisp:nth-child(4) { left: 48%; animation-delay: 0.3s; height: 90px; }
.steam-wisp:nth-child(5) { left: 55%; animation-delay: 0.7s; height: 65px; }
.steam-wisp:nth-child(6) { left: 65%; animation-delay: 1.0s; height: 75px; }
.steam-wisp:nth-child(7) { left: 75%; animation-delay: 0.2s; height: 50px; }
.steam-wisp:nth-child(8) { left: 85%; animation-delay: 0.6s; height: 85px; }
.steam-wisp:nth-child(9) { left: 92%; animation-delay: 1.2s; height: 60px; }

@keyframes steamRise {
  0% { transform: translateY(0) scaleY(1) scaleX(1); opacity: 0.2; }
  30% { transform: translateY(-40px) scaleY(1.8) scaleX(0.6); opacity: 0.5; }
  70% { transform: translateY(-100px) scaleY(2.5) scaleX(0.3); opacity: 0.15; }
  100% { transform: translateY(-180px) scaleY(3) scaleX(0.1); opacity: 0; }
}

.food-hero .hero-content {
  text-align: center;
  position: relative;
  z-index: 2;
  animation: fadeInUp 1s ease;
}
.food-hero .hero-icon-row {
  display: flex;
  justify-content: center;
  gap: 15px;
  margin-bottom: 20px;
  font-size: 2.5rem;
  animation: float 4s ease-in-out infinite;
}
.food-hero h1 {
  font-family: var(--font-title);
  font-size: 3.5rem;
  color: var(--food-gold);
  letter-spacing: 8px;
  margin-bottom: 8px;
  text-shadow: 0 0 50px rgba(212,168,83,0.4), 0 4px 20px rgba(200,121,65,0.3);
}
.food-hero .hero-desc {
  font-family: var(--font-poetry);
  font-size: 1.3rem;
  color: var(--food-text-dim);
  letter-spacing: 4px;
  margin-bottom: 12px;
}
.food-hero .hero-sub {
  color: var(--food-text-muted);
  font-size: 0.9rem;
  letter-spacing: 2px;
}

/* ---- 筷箸分隔线 ---- */
.chopstick-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 15px 0;
}
.chopstick-divider .stick {
  width: 2px;
  height: 50px;
  background: linear-gradient(180deg, var(--food-gold), var(--food-amber) 60%, transparent);
  border-radius: 1px;
  opacity: 0.5;
}
.chopstick-divider .dot {
  width: 5px; height: 5px;
  background: var(--food-gold);
  border-radius: 50%;
  box-shadow: 0 0 8px rgba(212,168,83,0.4);
}

/* ---- 通用 Section ---- */
.food-section {
  padding: 70px 0;
  position: relative;
}
.food-section-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* ---- 模块标题 ---- */
.food-module-title {
  text-align: center;
  margin-bottom: 50px;
}
.food-module-title .module-num {
  display: inline-block;
  font-family: var(--font-title);
  font-size: 0.8rem;
  color: var(--food-amber);
  letter-spacing: 3px;
  padding: 3px 16px;
  border: 1px solid rgba(200,121,65,0.3);
  border-radius: 20px;
  margin-bottom: 12px;
}
.food-module-title h2 {
  font-family: var(--font-title);
  font-size: 2.6rem;
  color: var(--food-gold);
  letter-spacing: 5px;
  margin-bottom: 10px;
}
.food-module-title .subtitle {
  font-family: var(--font-poetry);
  font-size: 1.1rem;
  color: var(--food-text-dim);
  letter-spacing: 2px;
}

/* ---- 装饰食材漂浮粒子 ---- */
.floating-ingredients {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.float-ing {
  position: absolute;
  font-size: 1.5rem;
  opacity: 0.2;
  animation: ingredientFloat 8s ease-in-out infinite;
}
.float-ing:nth-child(1) { left: 5%; top: 20%; animation-delay: 0s; }
.float-ing:nth-child(2) { left: 15%; top: 60%; animation-delay: 1.2s; }
.float-ing:nth-child(3) { left: 25%; top: 35%; animation-delay: 2.4s; }
.float-ing:nth-child(4) { left: 40%; top: 75%; animation-delay: 0.6s; }
.float-ing:nth-child(5) { left: 55%; top: 25%; animation-delay: 3.0s; }
.float-ing:nth-child(6) { left: 65%; top: 55%; animation-delay: 1.8s; }
.float-ing:nth-child(7) { left: 78%; top: 40%; animation-delay: 4.2s; }
.float-ing:nth-child(8) { left: 88%; top: 70%; animation-delay: 2.0s; }
.float-ing:nth-child(9) { left: 92%; top: 15%; animation-delay: 5.0s; }

@keyframes ingredientFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.15; }
  25% { transform: translate(30px, -25px) rotate(5deg); opacity: 0.25; }
  50% { transform: translate(10px, -15px) rotate(-3deg); opacity: 0.2; }
  75% { transform: translate(-20px, 10px) rotate(8deg); opacity: 0.18; }
}

/* ================================================================
   模块1: 千年食脉 — 横向滚动时间轴
   ================================================================ */
.timeline-scroll {
  position: relative;
  overflow: hidden;
  padding: 30px 0 40px;
  cursor: grab;
}
.timeline-scroll::-webkit-scrollbar { display: none; }
.timeline-track {
  display: flex;
  gap: 25px;
  width: max-content;
  animation: timelineAutoScroll 35s linear infinite;
}
.timeline-scroll:hover .timeline-track {
  animation-play-state: paused;
}
@keyframes timelineAutoScroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.timeline-node {
  flex: 0 0 300px;
  background: var(--food-card-bg);
  border: 1px solid var(--food-border);
  border-radius: 16px;
  padding: 35px 28px;
  position: relative;
  transition: all 0.4s ease;
  cursor: default;
}
.timeline-node:hover {
  border-color: var(--food-border-glow);
  box-shadow: 0 8px 35px rgba(200,121,65,0.2), 0 0 0 1px rgba(212,168,83,0.15);
  transform: translateY(-3px);
}
.timeline-node .tn-era {
  font-family: var(--font-title);
  font-size: 2.2rem;
  color: var(--food-gold);
  letter-spacing: 4px;
  margin-bottom: 4px;
}
.timeline-node .tn-event {
  font-size: 1.05rem;
  color: var(--food-text);
  font-weight: bold;
  letter-spacing: 1px;
  margin-bottom: 12px;
}
.timeline-node .tn-desc {
  color: var(--food-text-dim);
  font-size: 0.9rem;
  line-height: 1.9;
  margin-bottom: 15px;
}
.timeline-node .tn-quote {
  background: rgba(212,168,83,0.06);
  border-left: 2px solid var(--food-gold);
  padding: 10px 16px;
  border-radius: 0 6px 6px 0;
  font-family: var(--font-poetry);
  color: var(--food-text-dim);
  font-size: 0.85rem;
  letter-spacing: 1px;
  line-height: 1.7;
}
.timeline-node .tn-icon {
  position: absolute;
  top: -15px;
  right: -10px;
  font-size: 3rem;
  opacity: 0.3;
  pointer-events: none;
}
.timeline-node .tn-connector {
  position: absolute;
  right: -25px;
  top: 50%;
  width: 25px;
  height: 2px;
  background: linear-gradient(90deg, var(--food-gold), transparent);
  opacity: 0.4;
}
.timeline-node:last-child .tn-connector { display: none; }

/* ================================================================
   模块2: 九州食图 — 地域美食网格
   ================================================================ */
.region-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
.region-card {
  background: var(--food-card-bg);
  border: 1px solid var(--food-border);
  border-radius: 14px;
  padding: 30px 22px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: all 0.45s ease;
  cursor: default;
}
.region-card:hover {
  border-color: var(--food-border-glow);
  transform: translateY(-5px);
  box-shadow: 0 12px 40px rgba(200,121,65,0.25);
}
.region-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(212,168,83,0.12), transparent 50%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}
.region-card:hover::after { opacity: 1; }
.region-card .rc-icon {
  font-size: 3.2rem;
  margin-bottom: 12px;
  display: block;
  transition: transform 0.3s ease;
}
.region-card:hover .rc-icon { transform: scale(1.15); }
.region-card .rc-region {
  font-family: var(--font-title);
  font-size: 0.75rem;
  color: var(--food-amber);
  letter-spacing: 2px;
  margin-bottom: 4px;
  padding: 2px 12px;
  border: 1px solid rgba(200,121,65,0.2);
  border-radius: 12px;
  display: inline-block;
}
.region-card .rc-name {
  font-family: var(--font-title);
  font-size: 1.4rem;
  color: var(--food-gold);
  letter-spacing: 3px;
  margin: 8px 0;
}
.region-card .rc-desc {
  color: var(--food-text-dim);
  font-size: 0.88rem;
  line-height: 1.7;
}
.region-card.region-featured {
  grid-column: span 2;
  background: linear-gradient(135deg, rgba(45,15,26,0.95), rgba(58,26,21,0.9));
  display: flex;
  align-items: center;
  gap: 30px;
  text-align: left;
  padding: 35px;
}
.region-card.region-featured .rc-icon { font-size: 5rem; flex-shrink: 0; }

/* ---- 蒸汽粒子（卡片hover时出现） ---- */
.region-card .steam-burst {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.region-card:hover .steam-burst { opacity: 1; }
.steam-burst span {
  display: block;
  width: 2px;
  height: 30px;
  background: rgba(240,224,200,0.2);
  border-radius: 50%;
  margin: 3px auto;
  animation: miniSteam 2.5s ease-out infinite;
}
.steam-burst span:nth-child(2) { animation-delay: 0.3s; width: 3px; }
.steam-burst span:nth-child(3) { animation-delay: 0.6s; width: 1.5px; }
.steam-burst span:nth-child(4) { animation-delay: 0.9s; width: 2.5px; }
.steam-burst span:nth-child(5) { animation-delay: 1.2s; width: 2px; }
@keyframes miniSteam {
  0% { transform: translateY(0) scaleX(1); opacity: 0.3; }
  100% { transform: translateY(-40px) scaleX(0.3); opacity: 0; }
}

/* ================================================================
   模块3: 匠心手作 — 烹饪步骤动画
   ================================================================ */
.craft-area {
  background: linear-gradient(180deg, rgba(30,12,18,0.8), rgba(45,15,26,0.6));
  border: 1px solid var(--food-border);
  border-radius: 20px;
  padding: 50px 40px;
  position: relative;
  overflow: hidden;
}
/* 工坊蒸汽背景 */
.craft-steam-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.craft-steam-bg .cs-wisp {
  position: absolute;
  bottom: 0;
  background: rgba(240,224,200,0.1);
  border-radius: 50%;
  animation: craftSteamLong 4s ease-out infinite;
}
.cs-wisp:nth-child(1) { left: 10%; width: 4px; height: 70px; animation-delay: 0s; }
.cs-wisp:nth-child(2) { left: 20%; width: 5px; height: 90px; animation-delay: 0.5s; }
.cs-wisp:nth-child(3) { left: 30%; width: 3px; height: 60px; animation-delay: 1.0s; }
.cs-wisp:nth-child(4) { left: 45%; width: 6px; height: 100px; animation-delay: 0.3s; }
.cs-wisp:nth-child(5) { left: 55%; width: 4px; height: 80px; animation-delay: 0.8s; }
.cs-wisp:nth-child(6) { left: 65%; width: 5px; height: 85px; animation-delay: 1.3s; }
.cs-wisp:nth-child(7) { left: 75%; width: 3px; height: 65px; animation-delay: 0.6s; }
.cs-wisp:nth-child(8) { left: 85%; width: 4px; height: 75px; animation-delay: 1.1s; }
.cs-wisp:nth-child(9) { left: 95%; width: 5px; height: 95px; animation-delay: 1.6s; }
.cs-wisp:nth-child(10) { left: 50%; width: 6px; height: 110px; animation-delay: 0.2s; }
@keyframes craftSteamLong {
  0% { transform: translateY(0) scaleY(1) scaleX(1); opacity: 0.15; }
  30% { transform: translateY(-60px) scaleY(2) scaleX(0.5); opacity: 0.35; }
  70% { transform: translateY(-140px) scaleY(3) scaleX(0.25); opacity: 0.1; }
  100% { transform: translateY(-220px) scaleY(4) scaleX(0.1); opacity: 0; }
}

.craft-steps {
  display: flex;
  gap: 30px;
  justify-content: center;
  position: relative;
  z-index: 2;
  flex-wrap: wrap;
}
.craft-step {
  flex: 1;
  min-width: 160px;
  max-width: 200px;
  text-align: center;
  position: relative;
}
.craft-step .cs-visual {
  width: 120px;
  height: 120px;
  margin: 0 auto 18px;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 40%, rgba(212,168,83,0.25), transparent 60%);
  border: 2px solid rgba(200,140,80,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  position: relative;
  transition: all 0.5s ease;
}
.craft-step:hover .cs-visual {
  border-color: var(--food-gold);
  box-shadow: 0 0 35px rgba(212,168,83,0.3), inset 0 0 20px rgba(212,168,83,0.1);
  animation: craftPulse 0.6s ease;
}
@keyframes craftPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
.craft-step .cs-num {
  position: absolute;
  top: -8px;
  right: -8px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--food-gold), var(--food-amber));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 0.9rem;
}
.craft-step .cs-name {
  font-family: var(--font-title);
  font-size: 1.3rem;
  color: var(--food-gold);
  letter-spacing: 3px;
  margin-bottom: 8px;
}
.craft-step .cs-desc {
  color: var(--food-text-dim);
  font-size: 0.85rem;
  line-height: 1.7;
}
/* 步骤间连线 */
.craft-step:not(:last-child)::after {
  content: '→';
  position: absolute;
  right: -30px;
  top: 60px;
  font-size: 1.5rem;
  color: var(--food-amber);
  opacity: 0.4;
}

/* ================================================================
   模块4: 食俗雅趣 — 折叠面板
   ================================================================ */
.customs-accordion {
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.customs-panel {
  background: var(--food-card-bg);
  border: 1px solid var(--food-border);
  border-radius: 14px;
  overflow: hidden;
  transition: all 0.4s ease;
}
.customs-panel.open {
  border-color: var(--food-border-glow);
  box-shadow: 0 4px 25px rgba(200,121,65,0.15);
}
.customs-panel .cp-header {
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 22px 28px;
  cursor: pointer;
  user-select: none;
  transition: background 0.3s ease;
}
.customs-panel .cp-header:hover {
  background: rgba(212,168,83,0.04);
}
.cp-header .cp-icon {
  font-size: 2.2rem;
  flex-shrink: 0;
  width: 55px;
  height: 55px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 40% 35%, rgba(212,168,83,0.2), transparent 60%);
  border-radius: 50%;
  border: 1px solid rgba(200,140,80,0.2);
}
.cp-header .cp-title {
  font-family: var(--font-title);
  font-size: 1.3rem;
  color: var(--food-gold);
  letter-spacing: 3px;
  flex: 1;
}
.cp-header .cp-arrow {
  font-size: 1.2rem;
  color: var(--food-text-muted);
  transition: transform 0.35s ease;
  flex-shrink: 0;
}
.customs-panel.open .cp-arrow { transform: rotate(180deg); color: var(--food-gold); }
.customs-panel .cp-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s cubic-bezier(0.4,0,0.2,1);
}
.customs-panel.open .cp-body {
  max-height: 400px;
}
.cp-body .cp-content {
  padding: 0 28px 28px;
  color: var(--food-text-dim);
  font-size: 0.93rem;
  line-height: 2;
  letter-spacing: 0.5px;
}

/* ================================================================
   模块5: 名人与食 — 3D翻转卡片
   ================================================================ */
.fame-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
  perspective: 1500px;
}
.fame-card {
  height: 380px;
  perspective: 1000px;
  cursor: pointer;
}
.fame-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.65s cubic-bezier(0.4,0,0.2,1);
  transform-style: preserve-3d;
}
.fame-card:hover .fame-card-inner {
  transform: rotateY(180deg);
}
.fame-front, .fame-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 16px;
  border: 1px solid var(--food-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 35px 24px;
  overflow: hidden;
}
.fame-front {
  background: var(--food-card-bg);
  justify-content: center;
  gap: 10px;
  transition: border-color 0.4s ease, box-shadow 0.4s ease;
}
.fame-card:hover .fame-front {
  border-color: var(--food-border-glow);
  box-shadow: 0 8px 35px rgba(200,121,65,0.25);
}
.fame-front .ff-icon {
  font-size: 3.8rem;
  line-height: 1;
}
.fame-front .ff-name {
  font-family: var(--font-title);
  font-size: 1.6rem;
  color: var(--food-gold);
  letter-spacing: 4px;
}
.fame-front .ff-tag {
  font-size: 0.78rem;
  color: var(--food-amber);
  letter-spacing: 2px;
  padding: 4px 16px;
  border: 1px solid rgba(200,121,65,0.25);
  border-radius: 12px;
}
.fame-front .ff-hint {
  position: absolute;
  bottom: 20px;
  color: var(--food-text-muted);
  font-size: 0.75rem;
  letter-spacing: 1px;
  opacity: 0.5;
  transition: opacity 0.3s ease;
}
.fame-card:hover .ff-hint { opacity: 1; }
.fame-back {
  background: linear-gradient(145deg, rgba(35,18,18,0.97), rgba(45,15,26,0.95));
  transform: rotateY(180deg);
  justify-content: flex-start;
  text-align: center;
  padding: 40px 22px 30px;
}
.fame-back .fb-title {
  font-family: var(--font-title);
  font-size: 1.35rem;
  color: var(--food-gold);
  letter-spacing: 3px;
  margin-bottom: 18px;
}
.fame-back .fb-story {
  color: var(--food-text-dim);
  font-size: 0.9rem;
  line-height: 2;
  margin-bottom: auto;
  padding: 0 4px;
}
.fame-back .fb-link {
  display: inline-block;
  padding: 10px 26px;
  border: 1px solid var(--food-gold);
  border-radius: 22px;
  color: var(--food-gold);
  font-family: var(--font-title);
  font-size: 0.9rem;
  letter-spacing: 2px;
  transition: all 0.3s ease;
  cursor: pointer;
  text-decoration: none;
}
.fame-back .fb-link:hover {
  background: rgba(212,168,83,0.15);
  box-shadow: 0 4px 18px rgba(212,168,83,0.3);
  transform: translateY(-1px);
}
.fame-back .fb-link-detail {
  margin-top: 8px;
  border-color: var(--food-amber);
  color: var(--food-amber);
  font-size: 0.82rem;
  padding: 8px 20px;
}

/* ================================================================
   模块6: 月饼博览馆 — 聚光灯画廊
   ================================================================ */
.gallery-showcase {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
}
.gallery-item {
  background: var(--food-card-bg);
  border: 1px solid var(--food-border);
  border-radius: 16px;
  padding: 35px 25px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: all 0.5s ease;
  cursor: default;
}
.gallery-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 30%, rgba(255,200,100,0.1), transparent 60%);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
}
.gallery-item:hover::before { opacity: 1; }
.gallery-item:hover {
  border-color: var(--food-border-glow);
  transform: translateY(-6px);
  box-shadow: 0 16px 50px rgba(200,121,65,0.3);
}
.gallery-item .gi-spotlight {
  position: absolute;
  top: -50px;
  left: 50%;
  transform: translateX(-50%);
  width: 120px;
  height: 120px;
  background: radial-gradient(circle, rgba(255,200,100,0.25) 0%, rgba(255,180,80,0.1) 40%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.5s ease;
}
.gallery-item:hover .gi-spotlight { opacity: 1; }
.gallery-item .gi-icon {
  font-size: 4rem;
  margin-bottom: 14px;
  display: block;
  position: relative;
  z-index: 2;
  transition: transform 0.4s ease;
}
.gallery-item:hover .gi-icon { transform: scale(1.1); }
.gallery-item .gi-name {
  font-family: var(--font-title);
  font-size: 1.5rem;
  color: var(--food-gold);
  letter-spacing: 4px;
  margin-bottom: 8px;
  position: relative;
  z-index: 2;
}
.gallery-item .gi-tags {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 12px;
  position: relative;
  z-index: 2;
}
.gallery-item .gi-tag {
  padding: 3px 12px;
  border-radius: 12px;
  font-size: 0.75rem;
  letter-spacing: 1px;
  border: 1px solid rgba(200,140,80,0.2);
  color: var(--food-text-dim);
}
.gallery-item .gi-info {
  color: var(--food-text-muted);
  font-size: 0.85rem;
  line-height: 1.7;
  position: relative;
  z-index: 2;
}
.gallery-item .gi-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s ease, margin-top 0.5s ease;
  position: relative;
  z-index: 2;
}
.gallery-item:hover .gi-detail {
  max-height: 200px;
  margin-top: 15px;
}
.gi-detail .gi-stat {
  display: flex;
  justify-content: space-around;
  padding: 12px 0;
  border-top: 1px solid rgba(200,140,80,0.15);
}
.gi-stat .stat-item {
  text-align: center;
}
.stat-item .stat-val {
  font-family: var(--font-title);
  font-size: 1.3rem;
  color: var(--food-gold);
}
.stat-item .stat-label {
  font-size: 0.7rem;
  color: var(--food-text-muted);
  letter-spacing: 1px;
}

/* ---- Footer适配 ---- */
.footer {
  background: rgba(26,16,16,0.95);
  border-top: 1px solid var(--food-border);
}

/* ---- 回到顶部适配 ---- */
.back-to-top {
  background: var(--food-card-bg);
  border-color: var(--food-border);
}
.back-to-top svg { stroke: var(--food-gold); }

/* ---- 导航栏在新背景的微调 ---- */
.navbar {
  background: rgba(26,16,16,0.75);
}
.navbar.scrolled {
  background: rgba(26,16,16,0.92);
}

/* ---- 页面过渡适配 ---- */
.page-transition {
  background: var(--food-bg-deep);
}

/* ================================================================
   响应式
   ================================================================ */
@media (max-width: 1024px) {
  .food-hero h1 { font-size: 2.5rem; letter-spacing: 5px; }
  .region-grid { grid-template-columns: repeat(2, 1fr); }
  .region-card.region-featured { grid-column: span 2; }
  .fame-grid { grid-template-columns: repeat(2, 1fr); }
  .fame-card { height: 400px; }
  .gallery-showcase { grid-template-columns: repeat(2, 1fr); }
  .craft-steps { gap: 20px; }
  .craft-step { min-width: 130px; }
  .craft-step:not(:last-child)::after { right: -22px; font-size: 1.2rem; top: 50px; }
}
@media (max-width: 768px) {
  .food-hero { height: 45vh; min-height: 320px; }
  .food-hero h1 { font-size: 2rem; letter-spacing: 4px; }
  .food-hero .hero-desc { font-size: 1rem; }
  .region-grid { grid-template-columns: 1fr; }
  .region-card.region-featured { grid-column: span 1; flex-direction: column; text-align: center; }
  .fame-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  .fame-card { height: 370px; }
  .gallery-showcase { grid-template-columns: 1fr; }
  .timeline-node { flex: 0 0 260px; }
  .craft-steps { flex-direction: column; align-items: center; }
  .craft-step:not(:last-child)::after { display: none; }
  .craft-step { max-width: 100%; }
  .food-module-title h2 { font-size: 1.8rem; }
  .craft-area { padding: 30px 20px; }
}

/* ---- 全局入场揭幕效果 ---- */
.food-reveal {
  opacity: 0;
  transform: translateY(35px);
  transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1), transform 0.8s cubic-bezier(0.4,0,0.2,1);
}
.food-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
