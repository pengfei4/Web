<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="中秋祝福寄语，写下心愿与祝福">
<title>祝福寄语 — 月满中华·情系中秋</title>
<link href="/css/common.css" rel="stylesheet">
<link href="/css/animations.css" rel="stylesheet">
<link href="/css/pages.css" rel="stylesheet">
<style>
  .blessing-hero-mini { text-align: center; padding: 60px 20px; position: relative; }
  .blessing-hero-mini .bh-illustration { font-size: 6rem; display: block; margin-bottom: 20px; animation: float 4s ease-in-out infinite; }
  .lantern-release-animation { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 5000; }
  .flying-lantern { position: absolute; pointer-events: none; animation: lanternFlyUp 8s ease-out forwards; font-size: 2rem; }
  @keyframes lanternFlyUp {
    0% { transform: translateY(0) translateX(0) scale(1); opacity: 1; }
    20% { transform: translateY(-15vh) translateX(30px) scale(1.1); opacity: 0.95; }
    50% { transform: translateY(-50vh) translateX(-20px) scale(0.9); opacity: 0.7; }
    80% { transform: translateY(-80vh) translateX(15px) scale(0.7); opacity: 0.3; }
    100% { transform: translateY(-120vh) translateX(0) scale(0.3); opacity: 0; }
  }
  .blessing-stats { display: flex; justify-content: center; gap: 40px; margin-bottom: 40px; flex-wrap: wrap; }
  .blessing-stat { text-align: center; padding: 20px 30px; background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 12px; min-width: 120px; }
  .blessing-stat .bs-num { font-family: var(--font-title); font-size: 2rem; color: var(--moon-gold); }
  .blessing-stat .bs-label { color: var(--text-muted); font-size: 0.85rem; margin-top: 5px; }
</style>
</head>
<body data-journey="blessing">
<div class="page-transition active"><div class="moon-loader"></div></div>
<nav class="navbar">
  <a href="/" class="nav-logo"><div class="logo-icon"></div><span>月满中华</span></a>
  <div class="nav-links">
    <% nav.forEach(function(item) { %>
      <a href="<%= item.href %>"<%= item.href === '/blessing' ? ' class="active"' : '' %>><%= item.label %></a>
    <% }); %>
  </div>
  <div class="nav-toggle"><span></span><span></span><span></span></div>
</nav>
<div class="bg-particles"></div>

<div class="lantern-release-animation" id="lanternLayer"></div>

<section class="page-hero" style="height:40vh; min-height:300px;">
  <div class="cloud-pattern"></div>
  <div class="hero-content">
    <span class="hero-icon">💝</span>
    <h1>千里共婵娟</h1>
    <p class="hero-desc">祝福寄语 · 心愿传递</p>
  </div>
</section>

<div class="page-content">
  <div class="blessing-hero-mini reveal">
    <span class="bh-illustration">🏮</span>
    <p style="color:var(--text-secondary);font-size:1.1rem;letter-spacing:2px;max-width:600px;margin:0 auto;line-height:2;">
      写下你的中秋祝福，让心愿化作孔明灯<br>飘向月空，传递最真挚的情感
    </p>
  </div>

  <div class="blessing-container">
    <div class="blessing-stats reveal">
      <div class="blessing-stat"><span class="bs-num" id="blessingCount"><%= stats.blessingCount %></span><span class="bs-label">祝福数</span></div>
      <div class="blessing-stat"><span class="bs-num" id="lanternCount">0</span><span class="bs-label">孔明灯</span></div>
    </div>

    <div class="blessing-input-area reveal">
      <textarea id="blessingText" placeholder="写下你的中秋祝福……" maxlength="100"></textarea>
      <div class="blessing-actions">
        <button class="btn btn-primary" onclick="sendBlessing()">🕊️ 放飞孔明灯</button>
        <button class="btn" onclick="sendQuickBlessing()">✨ 随机祝福</button>
      </div>
    </div>

    <div class="section-title reveal" style="margin-top:50px;">
      <h2>祝福墙</h2>
      <p class="subtitle">每一份祝福都值得被看见</p>
      <div class="divider"><span class="dot"></span></div>
    </div>

    <div class="blessing-wall" id="blessingWall">
      <% blessings.forEach(function(b) { %>
        <div class="blessing-card">
          <p class="bc-text"><%= b.text %></p>
          <p class="bc-time"><%= b.author %> · <%= b.created_at %></p>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="footer-content">
    <div class="footer-links">
      <% nav.forEach(function(item) { %><a href="<%= item.href %>"><%= item.label %></a><% }); %>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-info">
      <p><span class="highlight"><%= config.site_title %></span></p>
      <p><%= config.footer_text %></p>
    </div>
  </div>
</footer>
<div class="back-to-top" title="回到顶部">
  <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
</div>
<script src="/js/common.js"></script>
<script src="/js/moon-journey.js"></script>
<script>MoonJourney.start('blessing');</script>
<script>
(function() {
  'use strict';
  var blessingCount = <%= stats.blessingCount %>;
  var lanternTotal = 0;
  var quickBlessings = <%- JSON.stringify(quickBlessings.map(function(b) { return b.text; })) %>;

  function launchLantern(text) {
    var layer = document.getElementById('lanternLayer');
    if (!layer) return;
    var lantern = document.createElement('div');
    lantern.className = 'flying-lantern';
    lantern.textContent = '🏮';
    lantern.style.left = (Math.random() * 60 + 20) + '%';
    lantern.style.bottom = '-50px';
    lantern.style.animationDuration = (Math.random() * 4 + 6) + 's';
    lantern.title = text;
    layer.appendChild(lantern);
    lanternTotal++;
    document.getElementById('lanternCount').textContent = lanternTotal;
    setTimeout(function() {
      if (lantern.parentNode) lantern.parentNode.removeChild(lantern);
    }, 9000);
  }

  function addBlessingCard(text, author, time) {
    var wall = document.getElementById('blessingWall');
    if (!wall) return;
    var card = document.createElement('div');
    card.className = 'blessing-card';
    card.innerHTML = '<p class="bc-text">' + escapeHTML(text) + '</p><p class="bc-time">' + (author || '匿名') + ' · ' + (time || '刚刚') + '</p>';
    wall.insertBefore(card, wall.firstChild);
  }

  function escapeHTML(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  window.sendBlessing = function() {
    var textarea = document.getElementById('blessingText');
    if (!textarea) return;
    var text = textarea.value.trim();
    if (!text) {
      textarea.style.borderColor = '#e8734a';
      textarea.placeholder = '请先写下您的祝福再放飞哦~';
      setTimeout(function() { textarea.style.borderColor = ''; textarea.placeholder = '写下你的中秋祝福……'; }, 2000);
      return;
    }
    fetch('/api/blessings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: text, author: '匿名' })
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.success) {
        addBlessingCard(text, '匿名', '刚刚');
        launchLantern(text);
        blessingCount++;
        document.getElementById('blessingCount').textContent = blessingCount;
      }
    });
    textarea.value = '';
  };

  window.sendQuickBlessing = function() {
    var idx = Math.floor(Math.random() * quickBlessings.length);
    var text = quickBlessings[idx];
    fetch('/api/blessings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: text, author: '中秋祝福' })
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.success) {
        addBlessingCard(text, '中秋祝福', '刚刚');
        launchLantern(text);
        blessingCount++;
        document.getElementById('blessingCount').textContent = blessingCount;
      }
    });
  };

  var textarea = document.getElementById('blessingText');
  if (textarea) {
    textarea.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        window.sendBlessing();
      }
    });
  }

  setInterval(function() {
    if (lanternTotal < 30) {
      var idx = Math.floor(Math.random() * quickBlessings.length);
      launchLantern(quickBlessings[idx]);
    }
  }, 8000);
})();
</script>
</body>
</html>
