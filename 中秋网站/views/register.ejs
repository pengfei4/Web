<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>注册 — 月满中华·情系中秋</title>
<link href="/css/common.css" rel="stylesheet">
<style>
  body { background: var(--deep-blue); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
  .register-box { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 16px; padding: 50px 40px; width: 420px; max-width: 90vw; text-align: center; position: relative; overflow: hidden; }
  .register-box::before { content: ''; position: absolute; top: -80px; right: -80px; width: 200px; height: 200px; border-radius: 50%; border: 2px solid var(--moon-gold); opacity: 0.15; pointer-events: none; }
  .register-box::after { content: ''; position: absolute; bottom: -60px; left: -60px; width: 150px; height: 150px; border-radius: 50%; border: 2px solid var(--moon-gold); opacity: 0.1; pointer-events: none; }
  .register-box .logo { font-size: 3.5rem; margin-bottom: 10px; animation: float 3s ease-in-out infinite; }
  .register-box h1 { font-family: var(--font-title); color: var(--moon-gold); font-size: 1.6rem; margin-bottom: 6px; }
  .register-box .subtitle { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 25px; }
  .register-box input { width: 100%; padding: 12px 16px; margin-bottom: 14px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-subtle); border-radius: 8px; color: #fff; font-size: 1rem; outline: none; transition: border-color 0.3s; box-sizing: border-box; }
  .register-box input:focus { border-color: var(--moon-gold); }
  .register-box .btn { width: 100%; padding: 12px; font-size: 1.05rem; cursor: pointer; }
  .register-box .error { color: var(--warm-orange); margin-bottom: 14px; font-size: 0.9rem; }
  .register-box .success { color: #4caf84; margin-bottom: 14px; font-size: 0.9rem; }
  .register-box .links { margin-top: 18px; display: flex; justify-content: center; gap: 20px; }
  .register-box .links a { color: var(--text-muted); text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
  .register-box .links a:hover { color: var(--moon-gold); }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .register-box .hint { color: var(--text-muted); font-size: 0.75rem; margin-top: 4px; }
</style>
</head>
<body>
<div class="register-box">
  <div class="logo">🌙</div>
  <h1>注册新账号</h1>
  <p class="subtitle">加入月满中华，探索中秋文化</p>
  <% if (typeof error === 'string' && error) { %>
    <p class="error"><%= error %></p>
  <% } %>
  <form method="POST" action="/register">
    <input type="text" name="username" placeholder="用户名（2-20个字符）" maxlength="20" required autofocus>
    <input type="password" name="password" placeholder="密码（至少4位）" minlength="4" required>
    <input type="password" name="password2" placeholder="确认密码" minlength="4" required>
    <p class="hint">注册即自动登录</p>
    <button type="submit" class="btn btn-primary" style="margin-top:6px;">注 册</button>
  </form>
  <div class="links">
    <a href="/login">← 已有账号？去登录</a>
    <a href="/">返回首页</a>
  </div>
</div>
</body>
</html>
